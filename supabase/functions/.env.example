# Chave da IA — configure UMA das duas opções abaixo:
#
# Opção 1: Lovable Gateway (acesso via conta Lovable)
LOVABLE_API_KEY=

# Opção 2: Google AI Studio (gratuito — gere em https://aistudio.google.com/apikey)
AI_API_KEY=

# Mercado Pago (necessário apenas para a função mp-webhook)
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
