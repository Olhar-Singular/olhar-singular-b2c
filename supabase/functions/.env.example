# Chave da IA — configure UMA das duas opções abaixo:
#
# Opção 1: Lovable Gateway (acesso via conta Lovable)
LOVABLE_API_KEY=

# Opção 2: Google AI Studio (gratuito — gere em https://aistudio.google.com/apikey)
AI_API_KEY=

# Mercado Pago — Pix (necessário para create-checkout e mp-webhook)
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# Stripe — cartão de crédito (create-stripe-checkout e stripe-webhook)
# Modo de teste: use a Secret key (sk_test_...) do dashboard.
STRIPE_SECRET_KEY=
# Signing secret (whsec_...) gerado por `stripe listen` ou no dashboard de webhooks.
STRIPE_WEBHOOK_SECRET=
