# ╔═══════════════════════════════════════════════════════════════════╗
# ║  .env ÚNICO — serve o app (Vite) E as edge functions (make fn-serve)  ║
# ╚═══════════════════════════════════════════════════════════════════╝
# Copie para .env (`cp .env.example .env`) e preencha. Nunca commite o .env.

# ─── Supabase ───
# Remoto/produção: pegue no dashboard do projeto.
# Local (`make sb-start`): use os valores de `make sb-status` (URL http://localhost:54321 + anon key).
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Acesso direto ao Postgres remoto (opcional — fora do client supabase-js)
# DATABASE_PASSWORD=
# DATABASE_URL=

# ─── Segredos de backend (edge functions) — SEM prefixo VITE_ (não vão pro bundle) ───
# Chave da IA — Google AI Studio (gratuito — gere em https://aistudio.google.com/apikey)
AI_API_KEY=

# Mercado Pago — Pix (create-checkout e mp-webhook)
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# Stripe — cartão (create-stripe-checkout e stripe-webhook)
# Modo de teste: use a Secret key (sk_test_...) do dashboard.
STRIPE_SECRET_KEY=
# Signing secret (whsec_...) gerado por `stripe listen` ou no dashboard de webhooks.
STRIPE_WEBHOOK_SECRET=
